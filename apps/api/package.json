{
  "name": "@canchaya/api",
  "version": "0.1.0",
  "description": "NestJS API for CanchaYa",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src",
    "test": "jest",
    "typeorm": "typeorm-cli",
    "typeorm:migration:generate": "typeorm migration:generate -d ./typeorm.config.ts",
    "typeorm:migration:run": "typeorm migration:run -d ./typeorm.config.ts",
    "typeorm:migration:revert": "typeorm migration:revert -d ./typeorm.config.ts"
  },
  "dependencies": {
    "@canchaya/types": "file:../../packages/types",
    "@nestjs/common": "^10.2.18",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.18",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.2.18",
    "@nestjs/typeorm": "^9.0.1",
    "@nestjs/websockets": "^10.2.18",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.10.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
    "typeorm": "^0.3.16"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0"
  }
}
